{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist/esm",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "tsBuildInfoFile": ".esm.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.ts", "src/**/*.test-d.ts"]
}
